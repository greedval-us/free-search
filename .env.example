APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

OSINT_FIO_HTTP_USER_AGENT="FreeSearch-FIO/1.0"
OSINT_FIO_HTTP_TIMEOUT=12
OSINT_FIO_HTTP_RETRY_ATTEMPTS=1
OSINT_FIO_HTTP_RETRY_SLEEP=250
OSINT_SITE_HEALTH_HTTP_USER_AGENT="FreeSearch-SiteHealth/1.0"
OSINT_SITE_HEALTH_HTTP_ACCEPT="*/*"
OSINT_SITE_HEALTH_HTTP_TIMEOUT=10
OSINT_SITE_HEALTH_HTTP_MAX_REDIRECTS=5
OSINT_SITE_HEALTH_HTTP_VERIFY_SSL=false
OSINT_SITE_INTEL_WHOIS_IANA_SERVER=whois.iana.org
OSINT_SITE_INTEL_WHOIS_CONNECT_TIMEOUT=8
OSINT_SITE_INTEL_WHOIS_READ_TIMEOUT=8
OSINT_SITE_INTEL_WHOIS_READ_CHUNK_SIZE=2048
OSINT_SITE_INTEL_WHOIS_MAX_RESPONSE_BYTES=120000
OSINT_USERNAME_HTTP_CONNECT_TIMEOUT=6
OSINT_USERNAME_HTTP_TIMEOUT=8
OSINT_USERNAME_HTTP_MAX_REDIRECTS=5
OSINT_USERNAME_HTTP_USER_AGENT="Mozilla/5.0 (compatible; UraborosOSINT/1.0; +https://localhost)"
OSINT_USERNAME_HTTP_ACCEPT="text/html,application/xhtml+xml"
OSINT_DORKS_HTTP_CONNECT_TIMEOUT=8
OSINT_DORKS_HTTP_TIMEOUT=12
OSINT_DORKS_HTTP_USER_AGENT="FreeSearch-Dorks/1.0"
OSINT_DORKS_HTTP_ACCEPT="text/html,application/xhtml+xml,application/xml"
OSINT_DORKS_MAX_RESULTS=120
OSINT_DORKS_PER_PROVIDER_LIMIT=20
OSINT_DORKS_DORKS_PER_GOAL=3
OSINT_DORKS_DEFAULT_GOAL=all
OSINT_DORKS_MAX_TARGET_LENGTH=120
OSINT_DORKS_QUALITY_SNIPPET_MAX_LENGTH=320
OSINT_DORKS_QUALITY_MIN_TARGET_TOKEN_MATCHES=1
OSINT_DORKS_QUALITY_MIN_UNIQUE_TOKEN_RATIO=0.35
OSINT_DORKS_SOURCE_BING=true
OSINT_DORKS_SOURCE_DUCKDUCKGO=true
OSINT_DORKS_SOURCE_YAHOO=true
OSINT_DORKS_SOURCE_BRAVE=true
OSINT_DORKS_SOURCE_YANDEX=true
OSINT_DORKS_SOURCE_REDDIT=true
OSINT_DORKS_SCOPE_MODE_ENABLED=true
OSINT_TELEGRAM_ANALYTICS_PERIOD_MIN_DAYS=1
OSINT_TELEGRAM_ANALYTICS_PERIOD_MAX_DAYS=7
OSINT_TELEGRAM_ANALYTICS_CUSTOM_RANGE_MAX_DAYS=7
OSINT_TELEGRAM_ANALYTICS_SUMMARY_CACHE_TTL=60
OSINT_TELEGRAM_ANALYTICS_GROUP_BY_HOUR_THRESHOLD_HOURS=36
OSINT_TELEGRAM_ANALYTICS_TOP_POSTS_LIMIT=5
OSINT_TELEGRAM_ANALYTICS_TOP_DISTRIBUTION_LIMIT=5
OSINT_TELEGRAM_ANALYTICS_FETCH_MAX_PAGES=20
OSINT_TELEGRAM_ANALYTICS_FETCH_PAGE_LIMIT=100
OSINT_TELEGRAM_ANALYTICS_AUDIENCE_TOP_AUTHORS_SHARE_LIMIT=5
OSINT_TELEGRAM_ANALYTICS_AUDIENCE_MOST_ACTIVE_HOURS_LIMIT=3
OSINT_TELEGRAM_ANALYTICS_AUDIENCE_HOUR_MIN=0
OSINT_TELEGRAM_ANALYTICS_AUDIENCE_HOUR_MAX=23
OSINT_TELEGRAM_ANALYTICS_FRAUD_SUSPICIOUS_POST_EXCERPT_LENGTH=160
OSINT_TELEGRAM_ANALYTICS_FRAUD_SUSPICIOUS_POSTS_LIMIT=5
OSINT_TELEGRAM_ANALYTICS_FRAUD_RISK_MAX_SCORE=100
OSINT_TELEGRAM_ANALYTICS_FRAUD_RISK_MEDIUM_THRESHOLD=30
OSINT_TELEGRAM_ANALYTICS_FRAUD_RISK_HIGH_THRESHOLD=60
OSINT_TELEGRAM_MESSAGES_LIMIT_DEFAULT=20
OSINT_TELEGRAM_MESSAGES_LIMIT_MAX=100
OSINT_TELEGRAM_COMMENTS_LIMIT_DEFAULT=20
OSINT_TELEGRAM_COMMENTS_LIMIT_MAX=50
OSINT_TELEGRAM_PARSER_CUSTOM_RANGE_MAX_DAYS=31

VITE_APP_NAME="${APP_NAME}"
