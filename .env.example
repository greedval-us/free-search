APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =========================
# OSINT: FIO (поиск по ФИО)
# =========================
# User-Agent для внешних запросов модуля FIO.
OSINT_FIO_HTTP_USER_AGENT="FreeSearch-FIO/1.0"
# Таймаут HTTP-запроса (секунды).
OSINT_FIO_HTTP_TIMEOUT=12
# Количество повторов при ошибках.
OSINT_FIO_HTTP_RETRY_ATTEMPTS=1
# Пауза между повторами (миллисекунды).
OSINT_FIO_HTTP_RETRY_SLEEP=250

# ==============================
# OSINT: SiteIntel (сайт и WHOIS)
# ==============================
# User-Agent для проверок сайта.
OSINT_SITE_HEALTH_HTTP_USER_AGENT="FreeSearch-SiteHealth/1.0"
# Заголовок Accept для HTTP-проверок.
OSINT_SITE_HEALTH_HTTP_ACCEPT="*/*"
# Таймаут HTTP-запроса (секунды).
OSINT_SITE_HEALTH_HTTP_TIMEOUT=10
# Максимум редиректов при обходе.
OSINT_SITE_HEALTH_HTTP_MAX_REDIRECTS=5
# Проверять SSL-сертификат (true/false).
OSINT_SITE_HEALTH_HTTP_VERIFY_SSL=false
# WHOIS IANA-сервер для определения целевого WHOIS.
OSINT_SITE_INTEL_WHOIS_IANA_SERVER=whois.iana.org
# Таймаут подключения WHOIS (секунды).
OSINT_SITE_INTEL_WHOIS_CONNECT_TIMEOUT=8
# Таймаут чтения WHOIS-ответа (секунды).
OSINT_SITE_INTEL_WHOIS_READ_TIMEOUT=8
# Размер чанка чтения WHOIS (байт).
OSINT_SITE_INTEL_WHOIS_READ_CHUNK_SIZE=2048
# Максимальный размер WHOIS-ответа (байт).
OSINT_SITE_INTEL_WHOIS_MAX_RESPONSE_BYTES=120000

# ============================
# OSINT: Username (проверка юзнеймов)
# ============================
# Таймаут подключения к источнику (секунды).
OSINT_USERNAME_HTTP_CONNECT_TIMEOUT=6
# Общий таймаут запроса (секунды).
OSINT_USERNAME_HTTP_TIMEOUT=8
# Максимум редиректов.
OSINT_USERNAME_HTTP_MAX_REDIRECTS=5
# User-Agent для проверки профилей.
OSINT_USERNAME_HTTP_USER_AGENT="Mozilla/5.0 (compatible; UraborosOSINT/1.0; +https://localhost)"
# Заголовок Accept.
OSINT_USERNAME_HTTP_ACCEPT="text/html,application/xhtml+xml"

# ==================================
# OSINT: Telegram аналитика и лимиты
# ==================================
# Минимальный период аналитики (дней).
OSINT_TELEGRAM_ANALYTICS_PERIOD_MIN_DAYS=1
# Максимальный период аналитики (дней).
OSINT_TELEGRAM_ANALYTICS_PERIOD_MAX_DAYS=7
# Максимум дней для custom range.
OSINT_TELEGRAM_ANALYTICS_CUSTOM_RANGE_MAX_DAYS=7
# TTL кэша summary (секунды).
OSINT_TELEGRAM_ANALYTICS_SUMMARY_CACHE_TTL=60
# До какого диапазона строим группировку по часам.
OSINT_TELEGRAM_ANALYTICS_GROUP_BY_HOUR_THRESHOLD_HOURS=36
# Лимит топ-постов в summary.
OSINT_TELEGRAM_ANALYTICS_TOP_POSTS_LIMIT=5
# Лимит элементов в распределениях.
OSINT_TELEGRAM_ANALYTICS_TOP_DISTRIBUTION_LIMIT=5
# Лимиты пагинации при сборе данных.
OSINT_TELEGRAM_ANALYTICS_FETCH_MAX_PAGES=20
OSINT_TELEGRAM_ANALYTICS_FETCH_PAGE_LIMIT=100
# Ограничения для аудитории.
OSINT_TELEGRAM_ANALYTICS_AUDIENCE_TOP_AUTHORS_SHARE_LIMIT=5
OSINT_TELEGRAM_ANALYTICS_AUDIENCE_MOST_ACTIVE_HOURS_LIMIT=3
OSINT_TELEGRAM_ANALYTICS_AUDIENCE_HOUR_MIN=0
OSINT_TELEGRAM_ANALYTICS_AUDIENCE_HOUR_MAX=23
# Параметры антифрода.
OSINT_TELEGRAM_ANALYTICS_FRAUD_SUSPICIOUS_POST_EXCERPT_LENGTH=160
OSINT_TELEGRAM_ANALYTICS_FRAUD_SUSPICIOUS_POSTS_LIMIT=5
OSINT_TELEGRAM_ANALYTICS_FRAUD_RISK_MAX_SCORE=100
OSINT_TELEGRAM_ANALYTICS_FRAUD_RISK_MEDIUM_THRESHOLD=30
OSINT_TELEGRAM_ANALYTICS_FRAUD_RISK_HIGH_THRESHOLD=60
# Базовые лимиты выдачи Telegram-поиска/комментариев.
OSINT_TELEGRAM_MESSAGES_LIMIT_DEFAULT=20
OSINT_TELEGRAM_MESSAGES_LIMIT_MAX=100
OSINT_TELEGRAM_COMMENTS_LIMIT_DEFAULT=20
OSINT_TELEGRAM_COMMENTS_LIMIT_MAX=50
# Максимум дней для кастомного диапазона парсера.
OSINT_TELEGRAM_PARSER_CUSTOM_RANGE_MAX_DAYS=31

# ======================================
# OSINT: NewsMediaIntel (RSS + NewsAPI)
# ======================================
# API key for https://newsapi.org/
OSINT_NEWSAPI_KEY=
# Endpoint for article search (usually keep default).
OSINT_NEWSAPI_BASE_URL=https://newsapi.org/v2/everything
# ISO language code for NewsAPI search.
OSINT_NEWSAPI_LANGUAGE=ru
# Maximum number of articles per request (NewsAPI limit applies).
OSINT_NEWSAPI_PAGE_SIZE=30
# HTTP timeout in seconds.
OSINT_NEWSAPI_TIMEOUT=15

# =========================
# YouTube Data API v3
# =========================
YOUTUBE_DATA_API_KEY=
YOUTUBE_DATA_API_BASE_URL=https://www.googleapis.com/youtube/v3

# =========================
# Frontend
# =========================
VITE_APP_NAME="${APP_NAME}"

# =========================
# Telegram API (MadelineProto)
# =========================
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
